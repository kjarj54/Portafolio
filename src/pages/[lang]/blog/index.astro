---
import Layout from '@layouts/Layout.astro';
import Header from '@components/shared/Header.astro';
import SocialSideBar from '@components/shared/SocialSideBar.astro';
import Footer from '@components/shared/Footer.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const locale = lang === 'en' ? 'en-US' : 'es-CR';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const localizedPosts = posts.filter((post) => post.id.startsWith(`${lang}/`));
const sorted = localizedPosts.sort((a, b) =>
  (b.data.publishedAt?.valueOf() ?? 0) - (a.data.publishedAt?.valueOf() ?? 0)
);

const featuredPost = sorted[0];
const regularPosts = sorted.slice(1);

const formatDate = (date?: Date) =>
  date
    ? date.toLocaleDateString(locale, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })
    : '';
---

<Layout title={`${t('nav.blog')} | ${t('site.title')}`} description={t('site.description')}>
  <Header />
  <SocialSideBar />

  <main class="relative overflow-hidden pt-28 pb-16 md:pb-24">
    <div class="blog-orb blog-orb--one"></div>
    <div class="blog-orb blog-orb--two"></div>

    <section class="relative z-10 mx-auto w-full max-w-6xl px-6">
      <header class="reveal mb-12 rounded-2xl border border-border/80 bg-card/55 p-6 backdrop-blur-sm md:mb-16 md:p-10">
        <p class="mb-4 inline-flex items-center rounded-full border border-primary/40 bg-primary/10 px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.16em] text-primary">
          {t('blog.home.eyebrow')}
        </p>
        <h1 class="max-w-3xl text-3xl font-semibold leading-tight text-foreground md:text-5xl">
          {t('blog.home.heading')}
        </h1>
        <p class="mt-5 max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
          {t('blog.home.description')}
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={translatePath('/')} class="fx-btn px-5 py-2.5 text-sm">
            {t('blog.home.backHome')}
          </a>
        </div>
      </header>

      {featuredPost && (
        <article class="blog-feature-card reveal reveal-delay-1 mb-10 overflow-hidden rounded-2xl border border-primary/30 bg-card/70 shadow-[0_24px_70px_rgba(2,10,24,0.55)] md:mb-14">
          {featuredPost.data.coverImage && (
            <div class="relative h-48 overflow-hidden border-b border-border/70 sm:h-64">
              <img
                src={featuredPost.data.coverImage}
                alt={featuredPost.data.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
              <div class="blog-image-tint"></div>
            </div>
          )}

          <div class="p-6 md:p-8">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.12em] text-primary/90">
              {t('blog.home.featured')}
            </p>
            <h2 class="text-2xl font-semibold leading-tight text-foreground md:text-3xl">
              <a
                href={`/${lang}/blog/${featuredPost.id.split('/').pop()}`}
                class="transition-colors hover:text-primary"
              >
                {featuredPost.data.title}
              </a>
            </h2>
            <p class="mt-4 max-w-3xl text-sm leading-relaxed text-muted-foreground md:text-base">
              {featuredPost.data.description}
            </p>

            <div class="mt-6 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
              <time datetime={featuredPost.data.publishedAt?.toISOString()}>
                {formatDate(featuredPost.data.publishedAt)}
              </time>
              {featuredPost.data.tags.slice(0, 3).map((tag) => (
                <span class="rounded-full border border-border bg-background/55 px-2.5 py-1 font-mono text-[11px] text-primary/85">
                  #{tag}
                </span>
              ))}
            </div>

            <a
              href={`/${lang}/blog/${featuredPost.id.split('/').pop()}`}
              class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-all duration-300 hover:translate-x-1"
            >
              {t('blog.readMore')}
              <span aria-hidden="true">-></span>
            </a>
          </div>
        </article>
      )}

      <section class="reveal reveal-delay-2">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-foreground md:text-2xl">{t('blog.home.latest')}</h2>
            <p class="mt-2 text-sm text-muted-foreground">{t('blog.home.latestDescription')}</p>
          </div>
        </div>

        {regularPosts.length > 0 ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {regularPosts.map((post) => (
              <article class="blog-card group rounded-2xl border border-border/80 bg-card/50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/55 hover:shadow-[0_20px_40px_rgba(2,10,24,0.45)]">
                <div class="mb-3 flex items-center justify-between gap-3">
                  <time
                    datetime={post.data.publishedAt?.toISOString()}
                    class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground"
                  >
                    {formatDate(post.data.publishedAt)}
                  </time>
                  {post.data.tags[0] && (
                    <span class="rounded-full border border-primary/25 px-2.5 py-1 text-[11px] font-mono text-primary/85">
                      #{post.data.tags[0]}
                    </span>
                  )}
                </div>

                <h3 class="text-lg font-semibold leading-snug text-foreground transition-colors duration-300 group-hover:text-primary">
                  <a href={`/${lang}/blog/${post.id.split('/').pop()}`}>{post.data.title}</a>
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{post.data.description}</p>

                <a
                  href={`/${lang}/blog/${post.id.split('/').pop()}`}
                  class="mt-5 inline-flex items-center gap-1 text-sm text-primary/90 transition-all duration-300 group-hover:translate-x-1 group-hover:text-primary"
                >
                  {t('blog.readMore')}
                  <span aria-hidden="true">-></span>
                </a>
              </article>
            ))}
          </div>
        ) : !featuredPost ? (
          <div class="rounded-2xl border border-dashed border-border bg-card/40 p-8 text-center">
            <p class="text-lg font-medium text-foreground">{t('blog.home.empty')}</p>
            <p class="mt-2 text-sm text-muted-foreground">{t('blog.home.emptyHint')}</p>
          </div>
        ) : null}
      </section>
    </section>
  </main>

  <Footer />
</Layout>