---
import Layout from '@layouts/Layout.astro';
import Header from '@components/shared/Header.astro';
import SocialSideBar from '@components/shared/SocialSideBar.astro';
import Footer from '@components/shared/Footer.astro';
import Projects from '@components/projects/Projects.astro';
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('nav.projects')} | ${t('site.title')}`} description={t('site.description')}>
  <Header />
  <SocialSideBar />

  <main class="pt-12 md:pt-16">
    <Projects />
  </main>

  <Footer />
</Layout>