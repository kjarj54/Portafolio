---
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section
  class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden"
>
  <!-- Small blurred clusters to soften transitions between sections -->
  <div
    class="absolute top-[7%] left-[10%] h-64 w-64 rounded-full blur-3xl mix-blend-screen animate-float-slow"
    style="background: radial-gradient(circle, rgba(100,255,218,0.3) 0%, rgba(100,255,218,0.12) 42%, transparent 76%);"
  >
  </div>
  <div
    class="absolute top-[21%] right-[14%] h-52 w-52 rounded-full blur-3xl mix-blend-screen animate-float-slower"
    style="background: radial-gradient(circle, rgba(100,255,218,0.26) 0%, rgba(100,255,218,0.1) 44%, transparent 78%);"
  >
  </div>
  <div
    class="absolute top-[39%] left-[33%] h-40 w-40 rounded-full blur-2xl mix-blend-screen animate-float-slow"
    style="background: radial-gradient(circle, rgba(100,255,218,0.22) 0%, rgba(100,255,218,0.08) 46%, transparent 80%);"
  >
  </div>
  <div
    class="absolute bottom-[22%] right-[24%] h-56 w-56 rounded-full blur-3xl mix-blend-screen animate-float-slower"
    style="background: radial-gradient(circle, rgba(100,255,218,0.28) 0%, rgba(100,255,218,0.11) 40%, transparent 76%);"
  >
  </div>
  <div
    class="absolute bottom-[8%] left-[16%] h-44 w-44 rounded-full blur-2xl mix-blend-screen animate-float-slow"
    style="background: radial-gradient(circle, rgba(100,255,218,0.2) 0%, rgba(100,255,218,0.07) 44%, transparent 80%);"
  >
  </div>

  <div
    class="absolute inset-0 opacity-[0.018]"
    style="background-image: linear-gradient(rgba(100,255,218,0.32) 1px, transparent 1px), linear-gradient(90deg, rgba(100,255,218,0.32) 1px, transparent 1px); background-size: 60px 60px;"
  >
  </div>
  <div class="relative z-10 max-w-4xl mx-auto">
    <p
      class="font-mono text-primary text-sm md:text-base mb-6 opacity-0 animate-fade-in-up"
      style="animation-delay: 100ms; animation-fill-mode: forwards;"
    >
      {t("hero.greeting")}
    </p>

    <h1
      class="text-4xl sm:text-5xl md:text-7xl font-bold text-foreground mb-4 opacity-0 animate-fade-in-up tracking-tight"
      style="animation-delay: 200ms; animation-fill-mode: forwards;"
    >
      {t("hero.name")}.
    </h1>

    <h2
      class="text-3xl sm:text-4xl md:text-6xl font-bold text-muted-foreground mb-8 opacity-0 animate-fade-in-up"
      style="animation-delay: 300ms; animation-fill-mode: forwards;"
    >
      {t("hero.title")}.
    </h2>

    <p
      class="text-muted-foreground text-base md:text-lg max-w-xl leading-relaxed mb-12 opacity-0 animate-fade-in-up"
      style="animation-delay: 400ms; animation-fill-mode: forwards;"
    >
      {t("hero.description")}
      <a
        href="#experience"
        class="text-primary hover:underline underline-offset-4"
      >
        {t("hero.company")}
      </a>.
    </p>

    <div
      class="flex flex-wrap gap-4 opacity-0 animate-fade-in-up"
      style="animation-delay: 500ms; animation-fill-mode: forwards;"
    >
      <a href="#projects" class="fx-btn px-6 py-3 text-sm">
        {t("hero.projects")}
      </a>

      <a href="#contact" class="fx-btn fx-btn--ghost px-6 py-3 text-sm">
        {t("hero.contact")}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-12 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in"
    style="animation-delay: 1000ms; animation-fill-mode: forwards;"
  >
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs text-muted-foreground font-mono"
        >{t("hero.scroll")}</span
      >
      <div class="w-px h-12 bg-linear-to-b from-primary to-transparent"></div>
    </div>
  </div>
</section>
