---
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = [
  {
    company: t('experience.company.current'),
    role: t('experience.role.current'),
    period: t('experience.period.current'),
    description: [
      t('experience.item1'),
      t('experience.item2'),
      t('experience.item3'),
    ],
    technologies: ['Oracle APEX', 'Oracle Database', 'PL/SQL', 'JavaScript', 'HTML', 'CSS'],
  },{
    company: t('experience.company.freelance'),
    role: t('experience.role.freelance'),
    period: t('experience.period.freelance'),
    description: [
      t('experience.item4'),
      t('experience.item5'),
      t('experience.item6'),
    ],
    technologies: ['PostgreSQL', 'React', 'Astro.js', 'Azure', 'AWS'],
  },
];
---

<section id="experience" class="py-24 md:py-32 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="reveal">
      <h2 class="flex items-center gap-4 text-2xl md:text-3xl font-bold text-foreground mb-12">
        <span class="font-mono text-primary text-lg md:text-xl">02.</span>
        {t('experience.title')}
        <span class="flex-1 h-px bg-border max-w-xs"></span>
      </h2>
    </div>

    <div class="flex flex-col md:flex-row gap-6 md:gap-8 reveal reveal-delay-1">
      <!-- Tab list -->
      <div class="flex md:flex-col overflow-x-auto md:overflow-visible border-b md:border-b-0 md:border-l border-border" id="experience-tabs">
        {experiences.map((exp, index) => (
          <button
            data-tab={index}
            class={`experience-tab relative px-5 py-3 text-sm font-mono text-left whitespace-nowrap transition-colors ${
              index === 0 
                ? 'text-primary bg-primary/5' 
                : 'text-muted-foreground hover:text-primary hover:bg-primary/5'
            }`}
          >
            {exp.company}
            {index === 0 && (
              <span class="tab-indicator absolute bottom-0 md:bottom-auto md:left-0 left-0 w-full md:w-0.5 h-0.5 md:h-full bg-primary"></span>
            )}
          </button>
        ))}
      </div>

      <!-- Tab content -->
      <div class="flex-1 min-h-75" id="experience-content">
        {experiences.map((exp, index) => (
          <div 
            data-content={index}
            class={`experience-content ${index === 0 ? '' : 'hidden'}`}
          >
            <h3 class="text-xl font-medium text-foreground mb-1">
              {exp.role}
              <span class="text-primary"> @ {exp.company}</span>
            </h3>
            
            <p class="font-mono text-sm text-muted-foreground mb-6">
              {exp.period}
            </p>

            <ul class="space-y-4">
              {exp.description.map((item) => (
                <li class="flex gap-3 text-muted-foreground leading-relaxed">
                  <span class="text-primary mt-1.5 text-xs">▹</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-2 mt-6">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 text-xs font-mono text-primary bg-primary/10 rounded-full">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.experience-tab');
  const contents = document.querySelectorAll('.experience-content');
  
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetIndex = tab.getAttribute('data-tab');
      
      // Update tabs
      tabs.forEach((t) => {
        t.classList.remove('text-primary', 'bg-primary/5');
        t.classList.add('text-muted-foreground');
        const indicator = t.querySelector('.tab-indicator');
        if (indicator) indicator.remove();
      });
      
      tab.classList.add('text-primary', 'bg-primary/5');
      tab.classList.remove('text-muted-foreground');
      
      const indicator = document.createElement('span');
      indicator.className = 'tab-indicator absolute bottom-0 md:bottom-auto md:left-0 left-0 w-full md:w-0.5 h-0.5 md:h-full bg-primary';
      tab.appendChild(indicator);
      
      // Update content
      contents.forEach((content) => {
        const contentIndex = content.getAttribute('data-content');
        if (contentIndex === targetIndex) {
          content.classList.remove('hidden');
        } else {
          content.classList.add('hidden');
        }
      });
    });
  });
</script>
