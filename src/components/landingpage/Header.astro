---
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { key: 'nav.about', href: '#about' },
  { key: 'nav.experience', href: '#experience' },
  { key: 'nav.projects', href: '#projects' },
  { key: 'nav.contact', href: '#contact' },
];
---

<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a 
      href="#" 
      class="text-xl font-bold text-primary hover:opacity-80 transition-opacity"
    >
      {'<ARAUZ/>'}
    </a>
    
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map((item, index) => (
        <li>
          <a
            href={item.href}
            class="nav-link text-sm tracking-wide transition-colors hover:text-primary text-muted-foreground"
          >
            <span class="font-mono text-primary text-xs mr-1">0{index + 1}.</span>
            {t(item.key as any)}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="/cv.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex px-4 py-2 text-sm font-medium text-primary border border-primary rounded hover:bg-primary/10 transition-colors"
    >
      {t('nav.cv')}
    </a>

    <button 
      id="mobile-menu-btn"
      class="md:hidden text-foreground p-2"
      aria-label={t('nav.contact')}
    >
      <svg 
        class="w-6 h-6" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24"
      >
        <path 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          stroke-width="2" 
          d="M4 6h16M4 12h16M4 18h16" 
        />
      </svg>
    </button>
  </nav>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-background/95 backdrop-blur-md z-50">
    <div class="flex flex-col items-center justify-center h-full gap-8">
      <button 
        id="close-menu-btn"
        class="absolute top-6 right-6 text-foreground p-2"
        aria-label={t('nav.closeMenu')}
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      
      {navItems.map((item, index) => (
        <a
          href={item.href}
          class="mobile-nav-link text-xl text-foreground hover:text-primary transition-colors"
        >
          <span class="font-mono text-primary text-sm mr-2">0{index + 1}.</span>
          {t(item.key as any)}
        </a>
      ))}
      
      <a
        href="/cv.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 px-6 py-3 text-sm font-medium text-primary border border-primary rounded hover:bg-primary/10 transition-colors"
      >
        {t('nav.cv')}
      </a>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });
  
  closeMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
    document.body.style.overflow = '';
  });
  
  mobileNavLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>