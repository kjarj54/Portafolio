---
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const technologyGroups = [
  {
    title: t('about.techGroup.languages'),
    items: ['Java','TypeScript', 'JavaScript', 'Python', 'C++/C'],
  },
  {
    title: t('about.techGroup.frontend'),
    items: ['React', 'Astro', 'Next.js', 'Tailwind CSS'],
  },
  {
    title: t('about.techGroup.backend'),
    items: ['SpringBoot','Express', 'NestJS', 'FastAPI'],
  },
  {
    title: t('about.techGroup.databases'),
    items: ['PostgreSQL', 'MySQL', 'SQLite', 'Oracle'],
  },
];
---

<section id="about" class="py-24 md:py-32 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="reveal">
      <h2 class="flex items-center gap-4 text-2xl md:text-3xl font-bold text-foreground mb-12">
        <span class="font-mono text-primary text-lg md:text-xl">01.</span>
        {t('about.title')}
        <span class="flex-1 h-px bg-border max-w-xs"></span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      <div class="md:col-span-2 space-y-4 reveal reveal-delay-1">
        <p class="text-muted-foreground leading-relaxed">
          {t('about.paragraph1')} <span class="text-foreground font-medium">{t('about.paragraph1Name')}</span> {t('about.paragraph1Rest')}
        </p>
        
        <p class="text-muted-foreground leading-relaxed">
          {t('about.paragraph2')}
          <a href="#experience" class="text-primary hover:underline underline-offset-4">{t('about.company1')}</a>.
          {t('about.paragraph2Rest')}
        </p>

        <p class="text-muted-foreground leading-relaxed">
          {t('about.techTitle')}
        </p>

        <div class="grid gap-6 mt-6 sm:grid-cols-2">
          {technologyGroups.map((group, groupIndex) => (
            <div class="rounded-lg border border-border/60 bg-card/30 p-4 reveal" style={`transition-delay: ${200 + groupIndex * 80}ms;`}>
              <h3 class="text-sm font-semibold text-foreground mb-3 tracking-wide">{group.title}</h3>
              <ul class="space-y-2">
                {group.items.map((item) => (
                  <li class="flex items-center gap-2 text-sm text-muted-foreground">
                    <span class="text-primary text-xs">▹</span>
                    <span class="font-mono">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="relative group reveal reveal-delay-3 justify-self-center md:justify-self-end">
        <div class="relative w-full max-w-60 overflow-hidden rounded-2xl border border-border/60 bg-card/20 p-2 shadow-2xl shadow-black/20">
          <div class="relative overflow-hidden rounded-xl">
            <div class="absolute inset-0 bg-linear-to-br from-primary/15 via-background/5 to-primary/5"></div>
            <img
              src="https://i.ibb.co/MxpX66F0/Yo.jpg"
              alt="Foto de Kevin Arauz"
              class="block h-80 w-full object-cover object-top transition-transform duration-500 group-hover:scale-105 sm:h-96"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-linear-to-t from-background/35 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>