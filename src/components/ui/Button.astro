---
interface Props {
  text: string;
  loadingText?: string;
}

const { text, loadingText = 'Cargando...' } = Astro.props;
---

<button 
  type="submit" 
  data-submit-btn
  data-default-text={text}
  data-loading-text={loadingText}
  class="creative-submit-btn relative w-full py-3.5 px-6 rounded-xl overflow-hidden group disabled:opacity-70 disabled:cursor-not-allowed"
>
  <span class="btn-grid"></span>
  <span class="btn-sheen"></span>

  <span class="relative z-10 flex items-center justify-center gap-2">
    <span class="tracking-[0.12em] uppercase">[</span>
    <span data-btn-text class="terminal-btn-text">{text}</span>
    <span class="tracking-[0.12em] uppercase">]</span>
    <svg data-btn-arrow class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
    </svg>
    <svg data-btn-spinner class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
  </span>

  <span class="btn-corners" aria-hidden="true"></span>
</button>