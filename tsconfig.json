{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@i18n/*": ["./src/i18n/*"],
      "@components/*": ["./src/components/*"],
      "@landing/*": ["./src/components/landingpage/*"],
      "@assets/*": ["./src/assets/*"],
    }
  }
}
